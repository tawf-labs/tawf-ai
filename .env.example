# Tawf-AI Environment Variables

# ===========================================
# Server Configuration
# ===========================================
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ===========================================
# Database
# ===========================================
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tawfai?schema=public"

# ===========================================
# AI Service Configuration
# ===========================================
# Provider: ollama, openai, qwen
AI_PROVIDER=ollama

# Ollama Configuration
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:14b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# HuggingFace Configuration (alternative embeddings)
HUGGINGFACE_API_KEY=your_huggingface_api_key_here
HUGGINGFACE_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ===========================================
# Embedding Configuration
# ===========================================
# Provider: ollama, openai, huggingface
EMBEDDING_PROVIDER=ollama
EMBEDDING_DIMENSIONS=768
EMBEDDING_BATCH_SIZE=10

# ===========================================
# Scraper Configuration
# ===========================================
SCRAPER_USER_AGENT=Tawf-AI/1.0 (https://github.com/yourusername/tawf-ai)
SCRAPER_CONCURRENCY=3
SCRAPER_DELAY_MS=1000
SCRAPER_TIMEOUT_MS=30000
SCRAPER_MAX_PAGES=100

# ===========================================
# RAG Configuration
# ===========================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5
MIN_SIMILARITY_THRESHOLD=0.7

# ===========================================
# API Configuration
# ===========================================
# Optional: Enable API key authentication
API_KEY_ENABLED=false
API_KEY=your_api_key_here
API_RATE_LIMIT=100  # requests per minute

# ===========================================
# CORS Configuration
# ===========================================
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# ===========================================
# Feature Flags
# ===========================================
ENABLE_SCRAPER=true
ENABLE_SCREENING=true
ENABLE_CHAT=true
