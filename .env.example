# ===========================================
# Server
# ===========================================
PORT=3000
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ===========================================
# Database (Supabase)
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
# Keep DATABASE_URL for PGVectorStore direct connection
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tawfai"

# ===========================================
# Thaura AI (LLM)
# https://thaura.ai/api-platform
# ===========================================
THAURA_API_KEY=your_thaura_api_key_here
THAURA_BASE_URL=https://backend.thaura.ai/v1
THAURA_TEMPERATURE=0.7

# ===========================================
# Tavily Search
# https://tavily.com
# ===========================================
TAVILY_API_KEY=your_tavily_api_key_here
TAVILY_MAX_RESULTS=5

# ===========================================
# Embeddings (OpenAI-compatible)
# ===========================================
EMBEDDINGS_API_KEY=your_openai_api_key_here
# EMBEDDINGS_BASE_URL=  # Optional: custom endpoint
EMBEDDINGS_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=10

# ===========================================
# RAG
# ===========================================
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RESULTS=5
MIN_SIMILARITY_THRESHOLD=0.7

# ===========================================
# Scraper
# ===========================================
SCRAPER_USER_AGENT=Tawf-AI/1.0
SCRAPER_CONCURRENCY=3
SCRAPER_DELAY_MS=1000
SCRAPER_TIMEOUT_MS=30000
SCRAPER_MAX_PAGES=100

# ===========================================
# API
# ===========================================
API_KEY_ENABLED=false
API_KEY=your_api_key_here
API_RATE_LIMIT=100

# ===========================================
# CORS
# ===========================================
CORS_ORIGIN=*
CORS_CREDENTIALS=true

# ===========================================
# Features
# ===========================================
ENABLE_SCRAPER=true
ENABLE_SCREENING=true
ENABLE_CHAT=true

# ===========================================
# LangSmith (optional tracing)
# ===========================================
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=your_langsmith_api_key_here
